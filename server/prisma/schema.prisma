generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model clan {
  clan_id                Int           @id @default(autoincrement())
  name_clan              String
  description            String?
  clan_pic               String?       @default("assets/files/default_clan.png")
  visibility             String?       @default("public")
  created_at             DateTime?     @default(now())
  clan_member            clan_member[]
  feeling                feeling[]
  clan_feeling           clan_feeling[]
  share_share_clanToclan share[]       @relation("share_clanToclan")
}

model clan_member {
  member_id Int       @id @default(autoincrement())
  clan_id   Int
  user_id   Int
  role      String?   @default("aldeao")
  joined_at DateTime? @default(now())
  user      users      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  clan      clan      @relation(fields: [clan_id], references: [clan_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([clan_id, user_id], map: "sqlite_autoindex_clan_member_1")
}

model coments {
  coment_id                        Int       @id @default(autoincrement())
  coment                           String?
  user                             Int
  feeling                          Int
  created_at                       DateTime? @default(now())
  parent_id                        Int?
  feeling_coments_feelingTofeeling feeling   @relation("coments_feelingTofeeling", fields: [feeling], references: [feeling_id], onDelete: Cascade, onUpdate: NoAction)
  user_coments_userTouser          users      @relation("coments_userTouser", fields: [user], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  coments                          coments?  @relation("comentsTocoments", fields: [parent_id], references: [coment_id], onDelete: Cascade, onUpdate: NoAction)
  other_coments                    coments[] @relation("comentsTocoments")
}

model feeling {
  feeling_id                       Int       @id @default(autoincrement())
  feeling                          String
  user                             Int
  visibility                       String?   @default("public")
  cla_id                           Int?
  created_at                       DateTime? @default(now())
  coments_coments_feelingTofeeling coments[] @relation("coments_feelingTofeeling")
  clan                             clan?     @relation(fields: [cla_id], references: [clan_id], onDelete: Cascade, onUpdate: NoAction)
  user_feeling_userTouser          users      @relation("feeling_userTouser", fields: [user], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  likes                            likes[]
  share_share_feelingTofeeling     share[]   @relation("share_feelingTofeeling")
}

model friendship {
  friendship_id                     Int       @id @default(autoincrement())
  sender_id                         Int
  receiver_id                       Int
  status                            String?   @default("pending")
  created_at                        DateTime? @default(now())
  user_friendship_receiver_idTouser users      @relation("friendship_receiver_idTouser", fields: [receiver_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  user_friendship_sender_idTouser   users      @relation("friendship_sender_idTouser", fields: [sender_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sender_id, receiver_id], map: "sqlite_autoindex_friendship_1")
}

model likes {
  like_id    Int       @id @default(autoincrement())
  user_id    Int
  feeling_id Int
  created_at DateTime? @default(now())
  feeling    feeling   @relation(fields: [feeling_id], references: [feeling_id], onDelete: Cascade, onUpdate: NoAction)
  user       users      @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, feeling_id], map: "sqlite_autoindex_likes_1")
}

model login {
  login_id              Int       @id @default(autoincrement())
  user                  Int
  password              String
  level_acess           String?   @default("user")
  created_at            DateTime? @default(now())
  user_login_userTouser users      @relation("login_userTouser", fields: [user], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model notification {
  notif_id                          Int       @id @default(autoincrement())
  user_id                           Int
  sender_id                         Int
  notif_type                        String
  reference_id                      Int?
  is_read                           Boolean?  @default(false)
  created_at                        DateTime? @default(now())
  user_notification_sender_idTouser users      @relation("notification_sender_idTouser", fields: [sender_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  user_notification_user_idTouser   users      @relation("notification_user_idTouser", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model share {
  share_id                       Int       @id @default(autoincrement())
  share                          String?
  user                           Int
  feeling                        Int
  clan                           Int
  created_at                     DateTime? @default(now())
  clan_share_clanToclan          clan      @relation("share_clanToclan", fields: [clan], references: [clan_id], onDelete: Cascade, onUpdate: NoAction)
  feeling_share_feelingTofeeling feeling   @relation("share_feelingTofeeling", fields: [feeling], references: [feeling_id], onDelete: Cascade, onUpdate: NoAction)
  user_share_userTouser          users      @relation("share_userTouser", fields: [user], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  user_id                                   Int            @id @default(autoincrement())
  first_name                                String
  last_name                                 String?
  phone                                     BigInt?
  email                                     String
  birthdate                                 DateTime?
  profile_pic                               String?        @default("assets/files/default_avatar.png")
  wallpaper_pic                             String?        @default("assets/files/default_wallpaper.png")
  created_at                                DateTime?      @default(now())
  clan_member                               clan_member[]
  coments_coments_userTouser                coments[]      @relation("coments_userTouser")
  feeling_feeling_userTouser                feeling[]      @relation("feeling_userTouser")
  clan_feeling_clan_feeling_userTouser      clan_feeling[] @relation("clan_feeling_userTouser")
  clan_coments_clan_coments_userTouser      clan_coments[] @relation("clan_coments_userTouser")
  clan_likes                                clan_likes[]
  friendship_friendship_receiver_idTouser   friendship[]   @relation("friendship_receiver_idTouser")
  friendship_friendship_sender_idTouser     friendship[]   @relation("friendship_sender_idTouser")
  likes                                     likes[]
  login_login_userTouser                    login[]        @relation("login_userTouser")
  notification_notification_sender_idTouser notification[] @relation("notification_sender_idTouser")
  notification_notification_user_idTouser   notification[] @relation("notification_user_idTouser")
  share_share_userTouser                    share[]        @relation("share_userTouser")

  @@map("users")
}

model clan_feeling {
  feeling_id                            Int            @id @default(autoincrement())
  feeling                               String
  user                                  Int
  visibility                            String?        @default("public")
  cla_id                                Int
  created_at                            DateTime?      @default(now())
  clan_coments                          clan_coments[]
  clan                                  clan           @relation(fields: [cla_id], references: [clan_id], onDelete: Cascade, onUpdate: NoAction)
  user_clan_feeling_userTouser          users          @relation("clan_feeling_userTouser", fields: [user], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  clan_likes                            clan_likes[]
}

model clan_likes {
  like_id      Int          @id @default(autoincrement())
  user_id      Int
  feeling_id   Int
  created_at   DateTime?    @default(now())
  clan_feeling clan_feeling @relation(fields: [feeling_id], references: [feeling_id], onDelete: Cascade, onUpdate: NoAction)
  user         users        @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, feeling_id], map: "sqlite_autoindex_clan_likes_1")
}

model clan_coments {
  coment_id                             Int          @id @default(autoincrement())
  coment                                String?
  user                                  Int
  feeling                               Int
  created_at                            DateTime?    @default(now())
  parent_id                             Int?
  clan_feeling                          clan_feeling @relation(fields: [feeling], references: [feeling_id], onDelete: Cascade, onUpdate: NoAction)
  user_clan_coments_userTouser          users        @relation("clan_coments_userTouser", fields: [user], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  clan_coments                          clan_coments? @relation("clan_comentsToclan_coments", fields: [parent_id], references: [coment_id], onDelete: Cascade, onUpdate: NoAction)
  other_clan_coments                    clan_coments[] @relation("clan_comentsToclan_coments")
}
